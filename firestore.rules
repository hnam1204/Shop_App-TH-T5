rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /categories/{categoryId} {
      allow read, write: if isSignedIn();
    }

    match /products/{productId} {
      allow read, write: if isSignedIn();
    }

    // Demo-only Week 8 rules. Production requires trusted role claims.
    match /week8_categories/{categoryId} {
      allow read, write: if isSignedIn();
    }

    match /week8_products/{productId} {
      allow read, write: if isSignedIn();
    }

    match /week8_counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /week8_payments/{paymentId} {
      allow create: if isSignedIn()
        && request.resource.data.customerId == request.auth.uid;
      allow read: if isSignedIn()
        && resource.data.customerId == request.auth.uid;
      allow update, delete: if false;
    }

    match /week8_payment_details/{detailId} {
      allow create: if isSignedIn()
        && getAfter(/databases/$(database)/documents/week8_payments/$(request.resource.data.paymentId)).data.customerId == request.auth.uid;
      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/week8_payments/$(resource.data.paymentId))
        && get(/databases/$(database)/documents/week8_payments/$(resource.data.paymentId)).data.customerId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
